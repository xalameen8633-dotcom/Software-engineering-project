@startuml activity_diagram_simplified
title Activity Diagram — Maintenance Management System Workflow

|Technician / IoT Sensors|
start
if (Request source?) then (Technician)
    :Log maintenance request;
else (IoT Sensors)
    :Detect abnormal temperature,\nvibration, or pressure reading;
    :Send abnormal sensor reading;
endif

|Maintenance Management System|
:Create maintenance request;
if (Triggered by IoT Sensors?) then (Yes)
    :Process sensor alert and\npredictive diagnostics;
else (No)
endif
:Send new request notification\nto supervisor;

|Supervisor|
:Review maintenance request;

if (Approve request?) then (Yes)
    :Assign work order to technician;
    :Track work order status;

    |Maintenance Management System|
    :Create work order;
    :Send work order notification\nto technician;

    |Technician|
    :View assigned work order;
    :Perform maintenance work;
    :Record labour and parts used;
    :Update work order;

    |Maintenance Management System|
    :Update maintenance history;
    :Update spare parts inventory;
    :Send completion notification\nto supervisor;

    |Supervisor|
    :Review completed work;

    if (Work satisfactory?) then (Yes)
        :Close work order;
    else (No)
        :Request rework;

        |Maintenance Management System|
        :Send rework notification\nto technician;

        |Technician|
        :Perform rework;
        :Update work order;

        |Maintenance Management System|
        :Send rework completion notification\nto supervisor;

        |Supervisor|
        :Review rework;
        :Close work order;
    endif

    |Maintenance Management System|
    :Update KPI reports;

    |Administrator|
    :Monitor KPI reports\n(downtime, response time,\nrepair cost);
    stop

else (No)
    |Supervisor|
    :Reject request;

    |Maintenance Management System|
    :Update request status;
    :Send rejection notification\nto technician;
    stop
endif

@enduml
