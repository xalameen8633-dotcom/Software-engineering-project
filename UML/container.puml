@startuml c4_L2_container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title C4 Level 2 — Container Diagram: Maintenance Management System

Person(technician, "Technician", "Logs maintenance requests\nand updates work order status")
Person(supervisor, "Supervisor", "Assigns and tracks\nwork orders")
Person(admin, "Administrator", "Monitors KPIs\nand manages reports")

System_Ext(iot, "IoT Sensors", "Detects abnormal temperature,\nvibration, or pressure readings")
System_Ext(notif, "Notification Service", "Delivers email and SMS\nalerts to users")

System_Boundary(mms, "Maintenance Management System") {

    Container(webapp, "Web Application", "React SPA", "Browser-based interface used by\ntechnicians, supervisors, and administrators")

    Container(mobile, "Mobile App", "React Native", "Mobile interface for field\ntechnicians to receive and\nupdate work orders on-site")

    Container(backend, "Backend API", "Node.js / Express", "Handles core business logic including\nauthentication, work orders, maintenance\nrequests, equipment records, spare parts\ninventory, and KPI calculations")

    Container(alert_eng, "Alert Engine", "Python", "Evaluates sensor data against\nthresholds, generates predictive alerts,\nand automatically creates maintenance requests")

    Container(iot_gw, "IoT Gateway", "MQTT Broker", "Receives and normalizes\nraw sensor payloads from\nIoT devices in the field")

    ContainerDb(db, "Central Database", "PostgreSQL", "Stores all system data:\nwork orders, equipment records,\nmaintenance history, spare parts,\nalerts, users, and KPI data")
}

Rel(technician, webapp, "Uses", "HTTPS")
Rel(technician, mobile, "Uses", "HTTPS")
Rel(supervisor, webapp, "Uses", "HTTPS")
Rel(admin, webapp, "Uses", "HTTPS")

Rel(webapp, backend, "Sends API requests", "REST / JSON")
Rel(mobile, backend, "Sends API requests", "REST / JSON")

Rel(backend, db, "Reads and writes", "SQL")
Rel(alert_eng, db, "Reads threshold config", "SQL")

Rel(iot, iot_gw, "Publishes sensor readings", "MQTT")
Rel(iot_gw, alert_eng, "Forwards normalized sensor events", "Internal")

Rel(alert_eng, backend, "Triggers work order creation", "Internal API")
Rel(backend, notif, "Triggers email and SMS notifications", "API")

Rel(notif, technician, "Delivers work order assignments\nand status updates")
Rel(notif, supervisor, "Delivers request alerts\nand completion notices")
Rel(notif, admin, "Delivers system alerts\nand KPI summaries")

Lay_L(technician, webapp)
Lay_U(supervisor, webapp)
Lay_R(admin, webapp)
Lay_D(iot, iot_gw)

@enduml
