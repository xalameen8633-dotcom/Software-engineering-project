@startuml sequence_detailed
title Sequence Diagram — Detailed (Developers): Predictive Maintenance Workflow

actor "IoT Sensors" as iot
participant "IoT Gateway\n(MQTT Broker)" as gateway
participant "Alert Engine\n(Python)" as alert
actor Supervisor as sup
actor Technician as tech
actor Administrator as admin
participant "Web Application\n(React SPA)" as web
participant "Backend API\n(Node.js / Express)" as backend
database "Central Database\n(PostgreSQL)" as db
participant "Notification Service" as notif

activate iot
iot -> gateway++ : Publish sensor payload\n(MQTT)
deactivate iot

gateway -> alert++ : Forward normalized sensor event
deactivate gateway

alert -> alert : Evaluate reading against threshold

alt Threshold exceeded
    alert -> backend++ : Create maintenance request\n(Internal API)
    backend -> db++ : Store maintenance request
    db --> backend : Save confirmation
    deactivate db

    backend -> db++ : Store predictive alert
    db --> backend : Save confirmation
    deactivate db

    backend -> notif++ : Trigger new request notification\n(API)
    notif --> sup : New predictive request alert\n(Email / SMS)
    deactivate notif

    sup -> web++ : Open maintenance request
    web -> backend : Get request details\n(REST / JSON)
    backend -> db++ : Read request details
    db --> backend : Return request details
    deactivate db
    backend --> web : Return request data\n(JSON)
    web --> sup : Display request details
    deactivate web

    sup -> web++ : Approve request and assign technician
    web -> backend : Submit assignment\n(REST / JSON)
    backend -> db++ : Create work order
    db --> backend : Save confirmation
    deactivate db

    backend -> db++ : Update request status to Approved
    db --> backend : Update confirmation
    deactivate db

    backend -> db++ : Update work order status to Assigned
    db --> backend : Update confirmation
    deactivate db

    backend -> notif++ : Trigger assignment notification\n(API)
    notif --> tech : Work order assignment\n(Email / SMS)
    deactivate notif

    tech -> web++ : Open assigned work order
    web -> backend : Get work order details\n(REST / JSON)
    backend -> db++ : Read work order, equipment,\nand spare parts details
    db --> backend : Return job details
    deactivate db
    backend --> web : Return work order details\n(JSON)
    web --> tech : Display job details
    deactivate web

    tech -> web++ : Submit completion update\n(labour hours + parts used)
    web -> backend : Update work order status to Completed\n(REST / JSON)

    backend -> db++ : Record maintenance history
    db --> backend : Save confirmation
    deactivate db

    backend -> db++ : Deduct spare parts from inventory
    db --> backend : Update confirmation
    deactivate db

    backend -> db++ : Update equipment status
    db --> backend : Update confirmation
    deactivate db

    backend -> db++ : Update work order status to Completed
    db --> backend : Update confirmation
    deactivate db

    backend --> web : Completion update saved\n(JSON)
    web --> tech : Display update confirmation
    deactivate web

    backend -> notif++ : Trigger completion notification\n(API)
    notif --> sup : Completion notification\n(Email / SMS)
    deactivate notif

    sup -> web++ : Review completed work order
    web -> backend : Get completed work order details\n(REST / JSON)
    backend -> db++ : Read completed work order details
    db --> backend : Return completed work order details
    deactivate db
    backend --> web : Return completed work order data\n(JSON)
    web --> sup : Display completed work order
    deactivate web

    alt Work satisfactory
        sup -> web++ : Confirm and close work order
        web -> backend : Update work order status to Closed\n(REST / JSON)

        backend -> db++ : Mark work order as Closed
        db --> backend : Update confirmation
        deactivate db

        backend -> db++ : Calculate and update KPI metrics
        db --> backend : Update confirmation
        deactivate db

        backend --> web : Close confirmation\n(JSON)
        web --> sup : Display work order closed confirmation
        deactivate web

        admin -> web++ : View dashboards and KPI reports
        web -> backend : Get KPI/report data\n(REST / JSON)
        backend -> db++ : Read KPI and report data
        db --> backend : Return KPI/report data
        deactivate db
        backend --> web : Return dashboard/report data\n(JSON)
        web --> admin : Display updated dashboards and reports
        deactivate web

    else Work unsatisfactory
        sup -> web++ : Reopen work order\nwith additional notes
        web -> backend : Update status to Rework Required\n(REST / JSON)

        backend -> db++ : Update work order status
        db --> backend : Update confirmation
        deactivate db

        backend -> db++ : Store supervisor notes
        db --> backend : Save confirmation
        deactivate db

        backend --> web : Rework status saved\n(JSON)
        web --> sup : Display rework confirmation
        deactivate web

        backend -> notif++ : Trigger rework notification\n(API)
        notif --> tech : Rework notification\n(Email / SMS)
        deactivate notif

        tech -> web++ : Submit rework completion
        web -> backend : Update work order status to Completed\n(REST / JSON)

        backend -> db++ : Record additional maintenance details
        db --> backend : Save confirmation
        deactivate db

        backend -> db++ : Update work order status to Completed
        db --> backend : Update confirmation
        deactivate db

        backend --> web : Rework completion saved\n(JSON)
        web --> tech : Display rework update confirmation
        deactivate web
    end

else Threshold not exceeded
    alert -> backend++ : Send normal sensor reading\n(Internal API)
    backend -> db++ : Log sensor reading
    db --> backend : Save confirmation
    deactivate db
end

deactivate backend
deactivate alert

@enduml